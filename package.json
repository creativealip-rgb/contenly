{
  "name": "contenly",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/run-parallel.js dev",
    "start": "node scripts/run-parallel.js start",
    "build": "npm run build --prefix backend && npm run build --prefix frontend",
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "smoke:contenly": "node scripts/smoke-contenly-e2e.mjs",
    "smoke:contenly:publish": "node scripts/smoke-contenly-e2e.mjs --publish",
    "smoke:video-script:mp4": "node scripts/smoke-video-script-mp4.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "dependencies": {
    "@nestjs/platform-socket.io": "^11.1.14",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/websockets": "^11.1.14",
    "isomorphic-dompurify": "^2.36.0",
    "resend": "^6.9.2",
    "socket.io": "^4.8.3",
    "stripe": "^20.3.1"
  }
}
