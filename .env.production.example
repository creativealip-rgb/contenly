# ===========================================
# CONTENLY PRODUCTION ENVIRONMENT VARIABLES
# Untuk Deploy ke Dokploy VPS
# ===========================================

# ===========================================
# DOMAIN CONFIGURATION
# ===========================================
DOMAIN=yourdomain.com
API_SUBDOMAIN=api

# ===========================================
# DATABASE (PostgreSQL di Dokploy)
# ===========================================
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Dokploy akan generate ini otomatis saat create database
DATABASE_URL=

# Atau gunakan ini jika setup manual:
DB_USER=contenly
DB_PASSWORD=your_secure_password_here
DB_NAME=contenly

# ===========================================
# REDIS CONFIGURATION
# ===========================================
# Dokploy akan generate ini otomatis
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_URL=

# ===========================================
# SECURITY KEYS (WAJIB!)
# Generate dengan: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ===========================================
ENCRYPTION_KEY=
BETTER_AUTH_SECRET=

# ===========================================
# AI SERVICE (OpenRouter)
# Dapatkan di: https://openrouter.ai/keys
# ===========================================
OPENROUTER_API_KEY=

# ===========================================
# EMAIL SERVICE (Resend)
# Dapatkan di: https://resend.com/api-keys
# ===========================================
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com

# ===========================================
# PAYMENT (Stripe)
# Dapatkan di: https://dashboard.stripe.com/apikeys
# ===========================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ===========================================
# OAUTH PROVIDERS (Opsional)
# ===========================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ===========================================
# APPLICATION URLs
# ===========================================
FRONTEND_URL=https://yourdomain.com
API_URL=https://api.yourdomain.com
NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api/v1

# ===========================================
# NODE ENVIRONMENT
# ===========================================
NODE_ENV=production
