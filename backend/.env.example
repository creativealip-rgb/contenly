# ===========================================
# CONTENLY BACKEND ENVIRONMENT VARIABLES
# ===========================================

# ===========================================
# REQUIRED - Application won't start without these
# ===========================================

# Database Connection (PostgreSQL/Supabase)
DATABASE_URL=postgresql://user:password@localhost:5432/contenly

# Encryption Key for WordPress passwords (64-char hex)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-character-hex-encryption-key-here-generate-one

# OpenRouter API Key (for AI content generation)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key

# Better Auth Secret (for session encryption)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=your-better-auth-secret-here

# ===========================================
# REQUIRED - Email Service (Resend)
# ===========================================

# Resend API Key for transactional emails
RESEND_API_KEY=re_your_resend_api_key

# Email sender address
EMAIL_FROM=noreply@yourdomain.com

# ===========================================
# OPTIONAL - Application URLs
# ===========================================

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:3000

# Backend API URL
API_URL=http://localhost:3001

# Environment
NODE_ENV=development

# ===========================================
# OPTIONAL - Redis (for job queues)
# ===========================================

# Redis connection for BullMQ job queues (RSS feed polling)
# If not set, feed polling will only work on-demand
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Or use a single Redis URL
# REDIS_URL=redis://localhost:6379

# ===========================================
# OPTIONAL - Stripe (for billing)
# ===========================================

STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ===========================================
# OPTIONAL - OAuth Providers
# ===========================================

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ===========================================
# DEV SANDBOX (Fase 1 Video Script Studio)
# ===========================================
# WARNING: Only enable in local development. NEVER set in production.
# When set to 1, all SessionAuthGuard checks are bypassed and all requests
# are treated as coming from a seeded dummy user "dev-bypass-user".
DEV_BYPASS_AUTH=0

# ===========================================
# AI PROVIDER (Custom OpenAI-compatible endpoint)
# ===========================================
# If OPENAI_BASE_URL is set, the OpenAiService will use that as a custom
# OpenAI-compatible endpoint and skip OpenRouter routing.
# Use this for self-hosted gateways or third-party OpenAI-compatible APIs.
# Example for Fase 1 dev sandbox:
# OPENAI_BASE_URL=https://9router-168-144-37-19.sslip.io/v1
# OPENAI_API_KEY=4dd43230cd861e78-fkhx5e-bb746474
# OPENAI_MODEL=cx/gpt-5.5

# Optional: Use a real api.openai.com key only for DALL-E/TTS while keeping
# the custom endpoint above for chat completions.
# OPENAI_NATIVE_API_KEY=sk-...
